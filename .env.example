# ── Azure Speech Service ─────────────────────────────────────
# Create a Speech resource in one of the supported regions:
#   - westeurope (recommended for EU)
#   - westus2
#   - southeastasia
# IMPORTANT: Use Standard S0 pricing tier to access avatars
AZURE_SPEECH_KEY=your-speech-service-key
AZURE_SPEECH_REGION=westeurope

# ── Azure Storage (optional - for persistent video storage) ──
AZURE_STORAGE_CONNECTION_STRING=your-storage-connection-string
AZURE_STORAGE_CONTAINER=podcast-videos

# ── Avatar Defaults ─────────────────────────────────────────
# Character: lisa, harry, jeff, max, lori
AVATAR_CHARACTER=lisa
# Style depends on character (see /avatars endpoint)
AVATAR_STYLE=casual-sitting
# Voice: Italian voices (see full list at /avatars endpoint)
TTS_VOICE=it-IT-DiegoNeural
TTS_LANGUAGE=it-IT
