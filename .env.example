# -- Azure Speech Service ----------------------------------------
# Create a Speech resource in one of the supported regions:
#   - westeurope (recommended for EU)
#   - westus2
#   - southeastasia
# IMPORTANT: Use Standard S0 pricing tier to access avatars
AZURE_SPEECH_KEY=your-speech-service-key
AZURE_SPEECH_REGION=westeurope

# -- Azure Storage (for persistent video storage) ---------------
AZURE_STORAGE_CONNECTION_STRING=your-storage-connection-string
AZURE_STORAGE_CONTAINER=podcast-videos

# -- Azure OpenAI (optional - for topic-to-script generation) ---
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com
AZURE_OPENAI_KEY=your-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# -- Avatar Defaults --------------------------------------------
AVATAR_CHARACTER=lisa
AVATAR_STYLE=casual-sitting
TTS_VOICE=it-IT-DiegoNeural
TTS_LANGUAGE=it-IT

# -- API Key Authentication (optional) --------------------------
# Set to enable X-API-Key header authentication
API_KEY=

# -- SAS URL expiry (hours) -------------------------------------
SAS_EXPIRY_HOURS=48

# -- Rate Limiting -----------------------------------------------
# Set to 0 to disable
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60
